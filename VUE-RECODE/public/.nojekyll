# 1. Add node_modules to your .gitignore so it never comes back
echo "node_modules/" >> .gitignore

# 2. Remove the folder from GitHub's memory (this won't delete it from your PC)
git rm -r --cached VUE-RECODE/node_modules/

# 3. Commit and push the clean-up
git add .
git commit -m "chore: remove node_modules and add .nojekyll"
git push origin main
